NODE_ENV=production
PORT=5001
DATABASE_URL=postgresql://user:password@host:5432/dbname
SESSION_SECRET=cambiar_por_un_secreto_largo_y_aleatorio
ADMIN_PASSWORD=cambiar_por_password_seguro
# Carpeta donde se guardan las canciones/imagenes/videos subidos desde el admin.
# Debe apuntar a un Volume persistente de Railway (o similar) para que no se
# borren los archivos en cada redeploy/reinicio. Si se omite, usa backend/uploads
# (disco efimero: se pierde en cada redeploy).
UPLOAD_DIR=/data/uploads
